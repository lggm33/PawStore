generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int    @id @default(autoincrement())
  nombre      String
  descripcion String @default("")
  precio      Int
  categoria   String
  imagen      String @default("")
  stock       Int    @default(0)
}

model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
  name         String
  email        String
  role         String @default("user")
}

model Order {
  id        Int      @id @default(autoincrement())
  nombre    String
  correo    String
  direccion String
  telefono  String   @default("")
  total     Float
  items     Json
  createdAt DateTime @default(now())
}
